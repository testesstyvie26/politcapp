{
  "name": "politapp",
  "private": true,
  "description": "Site estático (HTML/CSS/JS). Proxy opcional para API Portal da Transparência.",
  "scripts": {
    "build:tse-prefeitos-rj": "node scripts/build-tse-prefeitos-rj-2024.js",
    "sync:pref-tse-embed": "node scripts/sync-pref-tse-embed.js",
    "build:vereadores-rj": "node scripts/build-vereadores-rj-json.cjs",
    "build:vereadores-votos-zona": "node scripts/build-vereadores-votos-zona-rj.cjs",
    "build:vereadores-secao-exemplo": "node scripts/build-secao-exemplo-candidato-rj.cjs",
    "build:tse-df": "node scripts/build-tse-df-json-from-csv.cjs",
    "build:tse-partidos-rj": "node scripts/build-tse-receitas-partidos-rj.cjs",
    "build:executivo-tse-rj": "node scripts/build-executivo-tse-rj.cjs",
    "build:executivo-data": "npm run build:tse-partidos-rj && npm run build:vereadores-rj && npm run build:vereadores-votos-zona && npm run build:executivo-tse-rj",
    "dev": "node scripts/politapp-dev-server.cjs",
    "dev:portal-proxy": "node scripts/portal-transparencia-proxy.cjs",
    "dev:escuta-proxy": "node scripts/escuta-social-proxy.cjs",
    "deploy:worker": "npx wrangler deploy",
    "build:pdf-apresentacao": "node scripts/generate-apresentacao-pdf.mjs",
    "build:pdf-apresentacao-comercial": "node scripts/generate-apresentacao-pdf.mjs --comercial"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "iconv-lite": "^0.6.3",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.49.1"
  }
}
