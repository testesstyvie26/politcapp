
# Copie para .env e ajuste. O servidor Node precisa alcançar este host (mesma rede/VPC que o MySQL).
DB_HOST= ${{ secrets.DB_HOST }}
DB_PORT= ${{ secrets.DB_PORT }}
DB_USER= ${{ secrets.DB_USER }}
DB_PASSWORD=${{ secrets.DB_PASSWORD }}
DB_NAME=politapp_auth

SESSION_SECRET=

# true = expõe POST /api/register (desligue em produção)
ALLOW_REGISTER=true

PORT=8080

# Origens permitidas (front). GitHub Pages: https://SEU_USUARIO.github.io
# Se usar repositório em subcaminho: https://SEU_USUARIO.github.io/politapp
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://testesstyvie26.github.io/politapp,https://github.com,https://testesstyvie26.github.io

# true quando o front está em outro domínio (ex.: GitHub Pages) e o login precisa enviar cookie de sessão
SESSION_CROSS_SITE=false
TRUST_PROXY=0
