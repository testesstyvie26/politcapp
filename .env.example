# Copie para .env e ajuste. O servidor Node precisa alcançar este host (mesma rede/VPC que o MySQL).
DB_HOST=172.31.30.133
DB_PORT=3306
DB_USER=politapp_app
DB_PASSWORD=sua_senha
DB_NAME=politapp_auth

SESSION_SECRET=gere_um_segredo_longo_aleatorio

# true = expõe POST /api/register (desligue em produção)
ALLOW_REGISTER=true

PORT=8080

# Origens permitidas (front). GitHub Pages: https://SEU_USUARIO.github.io
# Se usar repositório em subcaminho: https://SEU_USUARIO.github.io/politapp
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# true quando o front está em outro domínio (ex.: GitHub Pages) e o login precisa enviar cookie de sessão
SESSION_CROSS_SITE=false
TRUST_PROXY=0

# Login com Google (OAuth 2) — https://console.cloud.google.com/apis/credentials — tipo "OAuth cliente Web"
# URIs de redirecionamento autorizados = exatamente GOOGLE_CALLBACK_URL (ex.: http://localhost:8080/api/auth/google/callback)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback
# Onde o usuário volta após o Google (site estático). Local: http://localhost:8080
# FRONTEND_BASE_URL=http://localhost:8080
#
# GitHub Actions: crie secrets em Settings → Secrets → Actions e use .github/workflows/deploy-backend.yml
# (GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, SESSION_SECRET, DB_*, GOOGLE_CALLBACK_URL, FRONTEND_BASE_URL, ALLOWED_ORIGINS).
